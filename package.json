{
  "name": "tamachicken",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "description": "TamaChicken — toddler-friendly chicken pet game",
  "author": {
    "name": "Marie Apellanes",
    "url": "https://apellanes.com.au"
  },
  "homepage": "https://apellanes.com.au",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "sync:version": "node scripts/sync-native-version.mjs",
    "bump:patch": "node scripts/bump-version.mjs patch",
    "bump:minor": "node scripts/bump-version.mjs minor",
    "bump:major": "node scripts/bump-version.mjs major",
    "mobile:sync": "npm run build && npx cap sync && npm run sync:version",
    "mobile:android": "npm run mobile:sync && npx cap open android",
    "mobile:ios": "npm run mobile:sync && npx cap open ios",
    "cap:sync": "npx cap sync",
    "cap:add:android": "npx cap add android",
    "cap:add:ios": "npx cap add ios"
  },
  "dependencies": {
    "@capacitor/app": "^8.0.0",
    "@capacitor/core": "^8.0.0",
    "@capacitor/haptics": "^8.0.0",
    "@capacitor/status-bar": "^8.0.0",
    "framer-motion": "^12.23.12",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@capacitor/android": "^8.0.0",
    "@capacitor/cli": "^8.0.0",
    "@capacitor/ios": "^8.0.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.2",
    "sharp": "^0.35.3",
    "typescript": "~5.9.2",
    "vite": "^7.1.3",
    "vite-plugin-pwa": "^1.3.0"
  }
}
